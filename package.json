{
  "name": "vitest-native",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "overrides": {
    "esbuild": "0.28.1",
    "shell-quote": "1.8.4",
    "vite": "8.0.16"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "bun run --filter vitest-native build",
    "test": "bun run --filter vitest-native test",
    "test:native": "bun run --filter vitest-native test:native",
    "test:native:android": "bun run --filter vitest-native test:native:android",
    "test:native:hot": "bun run --filter vitest-native test:native:hot",
    "test:native:hot:isolation": "bun run --filter vitest-native test:native:hot:isolation",
    "test:native:hot:soak": "bun run --filter vitest-native test:native:hot:soak",
    "test:consumers": "bun run build && bun run --filter vitest-native test:consumers",
    "test:example": "bun run build && bun run --filter '@vitest-native/example' test",
    "lint": "oxlint --deny-warnings packages/vitest-native/src/ packages/vitest-native/tests/ packages/vitest-native/tests-native/ packages/vitest-native/crosscheck/ packages/vitest-native/consumer-tests/ packages/vitest-native/scripts/",
    "lint:deps": "syncpack lint",
    "format": "oxfmt --write packages/vitest-native/src/ packages/vitest-native/tests/ packages/vitest-native/consumer-tests/ packages/vitest-native/scripts/",
    "format:check": "oxfmt --check packages/vitest-native/src/ packages/vitest-native/tests/ packages/vitest-native/consumer-tests/ packages/vitest-native/scripts/",
    "typecheck": "bun run --filter vitest-native typecheck",
    "clean": "bun run --filter vitest-native clean",
    "crosscheck": "bun run --filter vitest-native crosscheck"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "syncpack": "15.3.1",
    "tsdown": "0.21.10",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  }
}
